{
  "name": "reearth-terrain",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "node scripts/build-wasm.mjs",
    "data:egm08": "bash scripts/fetch-egm08.sh",
    "data:upload": "bash scripts/upload-local-r2.sh",
    "build": "npm run build:wasm && wrangler deploy --dry-run --outdir dist",
    "dev": "npm run build:wasm && wrangler dev",
    "deploy": "npm run build:wasm && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.5",
    "@types/mapbox__vector-tile": "^1.3.4",
    "@types/node": "^25.7.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.1"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "geotiff": "^3.0.5",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.1"
  }
}
